import turtle

t = turtle.Turtle()
t.speed(0)

# jednoduché "souhvězdí" (body + čáry)
body = [(0, 0), (50, 100), (100, 50), (150, 120), (200, 0)]

# vykreslení bodů
for x, y in body:
    t.penup()
    t.goto(x, y)
    t.pendown()
    t.dot(10)

# spojení bodů
t.penup()
t.goto(body[0])

t.pendown()
for x, y in body:
    t.goto(x, y)

t.hideturtle()
turtle.done()
